{
  "File skeleton": {
    "prefix": "skeleton",
    "description": "Full C file skeleton with section headers",
    "body": [
      "/*==============================================================================",
      " * Includes",
      " *============================================================================*/",
      "",
      "#include \"${1:${TM_FILENAME_BASE}}.h\"",
      "",
      "/*==============================================================================",
      " * Defines & Macros",
      " *============================================================================*/",
      "",
      "",
      "/*==============================================================================",
      " * Types",
      " *============================================================================*/",
      "",
      "",
      "/*==============================================================================",
      " * Private Variables",
      " *============================================================================*/",
      "",
      "",
      "/*==============================================================================",
      " * Private Function Prototypes",
      " *============================================================================*/",
      "",
      "",
      "/*==============================================================================",
      " * Public Functions",
      " *============================================================================*/",
      "",
      "",
      "/*==============================================================================",
      " * Private Functions",
      " *============================================================================*/",
      "",
      "$0"
    ]
  },
  "Section header": {
    "prefix": "section",
    "description": "Single section divider comment",
    "body": [
      "/*==============================================================================",
      " * ${1:Section Name}",
      " *============================================================================*/",
      "",
      "$0"
    ]
  },
  "Header guard": {
    "prefix": "guard",
    "description": "Include guard for header files",
    "body": [
      "#ifndef ${TM_FILENAME_BASE/(.*)/${1:/upcase}/}_H",
      "#define ${TM_FILENAME_BASE/(.*)/${1:/upcase}/}_H",
      "",
      "$0",
      "",
      "#endif /* ${TM_FILENAME_BASE/(.*)/${1:/upcase}/}_H */"
    ]
  },
  "Doxygen File Header": {
    "prefix": "doxyfile",
    "description": "Standard Doxygen header for file documentation",
    "body": [
      "/**",
      " * \\file ${TM_FILENAME}",
      " * \\author ${1:}",
      " * \\brief ${2:}",
      " * \\date ${CURRENT_YEAR}-${CURRENT_MONTH}-${CURRENT_DATE}",
      " *",
      " * \\copyright Copyright (c) ${CURRENT_YEAR}",
      " */",
      "",
      "$0"
    ]
  }
}
