{
  "Makefile Skeleton": {
    "prefix": "make",
    "description": "Cross-platform Makefile skeleton",
    "body": [
      "# Project name",
      "PROJECT = ${1:app}",
      "",
      "# Compiler and flags",
      "CXX = g++",
      "CXXFLAGS = -std=c++20 -Wall -Wextra -O2",
      "",
      "# OS-specific configurations",
      "ifeq (\\$(OS),Windows_NT)",
      "  TARGET = \\$(PROJECT).exe",
      "  CLEAN_CMD = del /f /q *.o \\$(PROJECT).exe 2>nul",
      "  RUN_CMD = .\\\\\\$(TARGET)",
      "else",
      "  TARGET = \\$(PROJECT)",
      "  CLEAN_CMD = rm -f *.o \\$(TARGET)",
      "  RUN_CMD = ./\\$(TARGET)",
      "endif",
      "",
      "# Source files and objects",
      "SRCS = \\$(wildcard *.cpp)",
      "OBJS = \\$(SRCS:.cpp=.o)",
      "",
      "# Default target",
      "all: \\$(TARGET)",
      "",
      "# Link objects to create executable",
      "\\$(TARGET): \\$(OBJS)",
      "\t\\$(CXX) \\$(CXXFLAGS) -o \\$@ \\$^",
      "",
      "# Compile source files into objects",
      "%.o: %.cpp",
      "\t\\$(CXX) \\$(CXXFLAGS) -c \\$< -o \\$@",
      "",
      "# Run the application",
      "run: all",
      "\t\\$(RUN_CMD)",
      "",
      "# Clean up build artifacts",
      "clean:",
      "\t-\\$(CLEAN_CMD)",
      "",
      "# Phony targets",
      ".PHONY: all run clean",
      "$0"
    ]
  }
}
